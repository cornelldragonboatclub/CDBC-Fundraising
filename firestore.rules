rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // Validation Blueprint for Leaderboard
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['netId', 'score', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.netId is string && data.netId.size() > 0 && data.netId.size() <= 64 &&
             data.score is number && data.score >= 0 && data.score <= 1000000 &&
             data.createdAt == request.time; // Temporal Integrity
    }

    match /leaderboard/{entryId} {
      // We allow open reads so the frontend can display the top scores
      // Note: We restrict the query on the frontend, but here anyone can read it
      allow read: if true;

      // Anyone can submit a score, we rely on the strict schema and size bounds to prevent abuse
      allow create: if isValidId(entryId) && isValidLeaderboardEntry(incoming());
      
      // Scores are immortal once created; no updates or deletes allowed from the client
      allow update, delete: if false;
    }
  }
}
